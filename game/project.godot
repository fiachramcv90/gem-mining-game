; Godot 4.3+ project — Gem Miner (the real game; vertical slice).
; Built to wayfinder/assets/0014-final-spec.md. Web-first: single-threaded
; Compatibility/WebGL2 export (spec §11), portrait touch-first (spec §2).

config_version=5

[application]

config/name="Gem Miner"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

; Web audio = Sample playback (spec §11): low latency without threads,
; no runtime bus effects. First tap is the audio-unlock gesture.
general/default_playback_type.web=2

[autoload]

GameState="*res://scripts/autoload/GameState.gd"
Wallet="*res://scripts/autoload/Wallet.gd"
Upgrades="*res://scripts/autoload/Upgrades.gd"
MinersLog="*res://scripts/autoload/MinersLog.gd"
Nudges="*res://scripts/autoload/Nudges.gd"
Settings="*res://scripts/autoload/Settings.gd"
SaveManager="*res://scripts/autoload/SaveManager.gd"
Sfx="*res://scripts/autoload/Sfx.gd"
Juice="*res://scripts/autoload/Juice.gd"

[display]

window/size/viewport_width=440
window/size/viewport_height=880
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation="portrait"

[input_devices]

; Touch-first (spec §2); mouse/keyboard fall out free on desktop.
pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
; Basis Universal / ETC2+ASTC import so the export's
; vram_texture_compression/for_mobile=true (spec §11) is coherent.
textures/vram_compression/import_etc2_astc=true
