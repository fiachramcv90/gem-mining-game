; Godot 4.3+ project — Gem Miner iOS Safari smoke test (wayfinder ticket 0011).
; THROWAWAY platform probe. One diagnostic screen: touch sprite, Sample-audio
; blip, on-screen renderer/FPS/memory readouts. Single-threaded Compatibility/
; WebGL2 export per ticket 0002, PWA-on for Add-to-Home-Screen testing.
;
; Separate from prototype/ (the 0004 dig-feel throwaway) on purpose: different
; question, different lifetime. Both get deleted once their ticket resolves.

config_version=5

[application]

config/name="Gem Miner — iOS Smoke Test (0011)"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

; Web audio = Sample playback (0002 §3): low latency without threads, no bus
; effects. This is the web-platform override; the diagnostic scene also forces
; it on the AudioStreamPlayer so the intent is legible either way.
general/default_playback_type.web=2

[display]

window/size/viewport_width=440
window/size/viewport_height=880
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation="portrait"

[input_devices]

pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
; Enable ETC2/ASTC + Basis Universal import so the export's
; vram_texture_compression/for_mobile=true (0002 §8) is coherent. Harmless here
; (the diagnostic scene draws in code, no imported textures), but correct.
textures/vram_compression/import_etc2_astc=true
